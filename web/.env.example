# Base URL of the Quartet demo server (the presenter's machine), reached over a tunnel when this
# frontend is deployed (e.g. Vercel). Every API and SSE call goes through it. No backend code or secret
# ever ships in the frontend.
#
# Local dev: leave this empty. Vite proxies /api to 127.0.0.1:8000 (see vite.config.ts).
# Deployed: set to the public tunnel URL, with no trailing slash, at build time.
VITE_API_BASE=

# Optional: dev only. Port of the local demo server that Vite proxies to (default 8000).
# VITE_API_PORT=8000
