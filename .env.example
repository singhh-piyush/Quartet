# LLM provider: local (default, free debugging) | aimlapi
LLM_PROVIDER=local

# AI/ML API key (required when LLM_PROVIDER=aimlapi)
AIML_API_KEY=

# Per-role models on AI/ML API (optional overrides). Verify against aimlapi.com/models.
SPEC_MODEL=
CODER_MODEL=
TESTER_MODEL=
REPAIRER_MODEL=

# Local OpenAI-compatible server model name (used when LLM_PROVIDER=local)
LOCAL_MODEL=local-model

# Band platform REST base for the conductor (Agent API). Default is fine; override only if needed.
BAND_REST_URL=https://app.band.ai
